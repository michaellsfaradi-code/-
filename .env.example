# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# XAI_API_KEY: Optional/Required for Grok / xAI integration endpoints.
# Users can get their keys from the xAI console and add them to their custom secrets.
XAI_API_KEY="MY_XAI_API_KEY"

# NETLAS_API_KEY: Netlas API key for active target intelligence lookup
NETLAS_API_KEY="dXGqEmneDz28k24ZhWnR21I5TKxugV0C"

# APIFY_API_KEY: Apify API key for web scraping and data extraction.
APIFY_API_KEY="MY_APIFY_API_KEY"

# MONGODB_URI: Connection string for MongoDB
MONGODB_URI=""


